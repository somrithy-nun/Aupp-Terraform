# Copy this file to terraform.tfvars and customize the values.

aws_region    = "us-east-1"
project_name  = "static-website"
instance_type = "t2.micro"

# (Optional) Name of an EXISTING EC2 key pair for SSH access.
# Create one in the AWS console first, or leave empty.
key_pair_name = ""

# Your static website GitHub repository (HTTPS clone URL).
github_repo_url = "https://github.com/your-username/your-static-site.git"
github_branch   = "main"

# Subdirectory containing index.html. Use "." if files are at the repo root.
site_subdir = "."

# Restrict SSH to your own IP for better security, e.g. "203.0.113.10/32".
ssh_ingress_cidr = "0.0.0.0/0"
